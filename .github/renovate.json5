{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':dependencyDashboard',
    ':timezone(UTC)',
    'group:allNonMajor',
    'group:nextjsMonorepo',
    'group:reactMonorepo',
    'group:typescript-eslintMonorepo',
    'group:tailwindcssMonorepo',
    'github>snapetech/seerrng//.github/renovate/actions.json5',
    'github>snapetech/seerrng//.github/renovate/docker.json5',
    'github>snapetech/seerrng//.github/renovate/groups.json5',
    'github>snapetech/seerrng//.github/renovate/helm.json5',
    'github>snapetech/seerrng//.github/renovate/labels.json5',
    'github>snapetech/seerrng//.github/renovate/pnpm.json5',
    'github>snapetech/seerrng//.github/renovate/semanticCommits.json5',
  ],
  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  suppressNotifications: ['prEditedNotification', 'prIgnoreNotification'],
  rebaseWhen: 'conflicted',
  labels: ['dependencies'],
  minimumReleaseAge: '7 days',
}
